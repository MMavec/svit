# Supabase (optional — Tier 4 panels show auth prompts when unconfigured)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# eBird API — wildlife observations (free from ebird.org/api/keygen)
EBIRD_API_KEY=

# AQICN — air quality data (free from aqicn.org/data-platform/token/)
AQICN_API_TOKEN=

# Ocean Networks Canada — ocean temperature (free from data.oceannetworks.ca)
ONC_API_TOKEN=

# MapTiler (optional — currently using CARTO basemaps, no key needed)
# PUBLIC_MAPTILER_KEY=
